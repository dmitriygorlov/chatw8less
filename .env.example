# Telegram bot
TELEGRAM_API_TOKEN=your_telegram_bot_token_here
ALLOWED_USER_IDS=123456789,987654321

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Recent dialog pairs included in assistant context.
# Food calculations always use only the current message.
# ASSISTANT_CONTEXT_DIALOGS=3

# Model configuration
GPT_MODEL_FAST=gpt-4o-mini
GPT_MODEL_SMART=gpt-5-mini
GPT_MODEL_ASSISTANT=gpt-5-mini
# GPT_MODEL_FAST_VISION=gpt-4o-mini
# GPT_MODEL_SMART_VISION=gpt-5-mini
# Optional for GPT-5-class models only. Leave empty for GPT-4o/4.1.
# GPT_REASONING_FAST=
# GPT_REASONING_SMART=low
GPT_REASONING_ASSISTANT=low

# Token limits
# Use at least 4096 when GPT_MODEL_FAST is a GPT-5-class reasoning model.
MAX_TOKENS_FAST=2048
# MAX_TOKENS_SMART=4096
MAX_TOKENS_ASSISTANT=4096

# Telegram username without @
SUPPORT_CONTACT=test

# Optional app settings
# HOUR_SHIFT=0
# DEFAULT_MODEL_MODE=fast
# OPENAI_PHOTO_DETAIL=high
# TOKENS_LOG_FILE=tokens.log

# Shared website + bot backend
SITE_URL=https://your-site.example.com
DATABASE_PATH=storage/chatw8less.sqlite3
WEB_SESSION_DAYS=30
WEB_COOKIE_SECURE=auto
RUN_TELEGRAM_IN_WEB=true

# Railway example:
# DATABASE_PATH=/app/storage/chatw8less.sqlite3
# WEB_COOKIE_SECURE=true
